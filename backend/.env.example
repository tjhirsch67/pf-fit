# PF Coach Backend — Environment Variables
# Copy this file to .env and fill in your values for local development.
# Never commit .env to version control.

# ─── Database ────────────────────────────────────────────────────────────────
# Production: Railway injects DATABASE_URL automatically.
# Local dev: use the Railway "Public URL" (Railway dashboard → Postgres → Variables),
# or a local Postgres instance.
DATABASE_URL=postgresql://postgres:password@localhost:5432/pf_coach

# ─── Auth ────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-this-to-a-48+-char-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# ─── Anthropic (Claude AI) ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Email (Mailtrap HTTP API) ───────────────────────────────────────────────
# Railway blocks outbound SMTP, so PF Coach uses the Mailtrap Send HTTP API.
MAILTRAP_API_TOKEN=
FROM_EMAIL=coach@pf-coach.app
FROM_NAME=PF Coach

# ─── App ─────────────────────────────────────────────────────────────────────
APP_ENV=development
# Comma-separated list of allowed CORS origins (the Netlify site URL in prod).
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:5500

# ─── Railway build ───────────────────────────────────────────────────────────
NIXPACKS_PYTHON_VERSION=3.11
