/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: no-referrer
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self' https://fonts.googleapis.com 'unsafe-inline'; font-src https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self' https://pf-fit-production.up.railway.app; manifest-src 'self'; base-uri 'self'; frame-ancestors 'none'

/js/*
  Cache-Control: no-cache

/css/*
  Cache-Control: no-cache
